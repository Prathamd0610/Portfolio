# Copy this file to ".env" and fill in the values.

# App mode: development | production
NODE_ENV=development

# Port the Express API listens on
PORT=5000

# Allowed CORS origin (your frontend URL)
FRONTEND_URL=http://localhost:5173

# MongoDB connection string — REQUIRED for the contact form to persist messages.
# Free cluster: https://www.mongodb.com/cloud/atlas
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/portfolio
MONGO_URI=
